# ==================== BACKEND (Java / Maven / Spring Boot) ====================

# Compiled output
backend/target/

# Maven wrapper
!backend/.mvn/wrapper/maven-wrapper.jar

# Spring Boot log
*.log
spring-output.log
spring-error.log

# H2 database files (si se usa modo file en lugar de in-memory)
*.db
*.mv.db
*.trace.db

# Application secrets (nunca subir credenciales)
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-local.properties

# ==================== FRONTEND (Node / React / Vite) ====================

# Dependencies
frontend/node_modules/

# Build output
frontend/dist/
frontend/dist-ssr/

# Vite / env locals
frontend/.env.local
frontend/.env.*.local
frontend-output.log
frontend-error.log

